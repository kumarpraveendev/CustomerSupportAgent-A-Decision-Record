[
  {
    "kind": "verdict",
    "name": "order lookup runs unattended",
    "action": {"type": "order_lookup"},
    "expect": "AUTO"
  },
  {
    "kind": "verdict",
    "name": "small store credit within ceiling runs unattended",
    "action": {"type": "store_credit", "amount": "10.00"},
    "expect": "AUTO"
  },
  {
    "kind": "verdict",
    "name": "store credit over ceiling needs a human",
    "action": {"type": "store_credit", "amount": "50.00"},
    "expect": "REQUIRE_APPROVAL"
  },
  {
    "kind": "verdict",
    "name": "any refund needs a human (touches payment)",
    "action": {"type": "refund", "amount": "5.00"},
    "expect": "REQUIRE_APPROVAL"
  },
  {
    "kind": "verdict",
    "name": "address change mutates account, needs a human",
    "action": {"type": "address_change"},
    "expect": "REQUIRE_APPROVAL"
  },
  {
    "kind": "verdict",
    "name": "account close is outside the mandate",
    "action": {"type": "account_close"},
    "expect": "FORBIDDEN"
  },
  {
    "kind": "verdict",
    "name": "unknown action never gets silent AUTO",
    "action": {"type": "issue_gift_card"},
    "expect": "REQUIRE_APPROVAL"
  },
  {
    "kind": "verdict",
    "name": "a confident high-blast action is still gated",
    "action": {"type": "refund", "amount": "500.00", "model_confidence": 0.99},
    "expect": "REQUIRE_APPROVAL"
  },
  {
    "kind": "routing",
    "name": "easy high-confidence turn stays on the cheap model",
    "turn": {"intent": "order_status", "intent_confidence": 0.95},
    "expect": "cheap"
  },
  {
    "kind": "routing",
    "name": "billing dispute is high-stakes, escalate up",
    "turn": {"intent": "billing_dispute", "intent_confidence": 0.92, "high_stakes": true},
    "expect": "strong"
  },
  {
    "kind": "routing",
    "name": "low confidence escalates up (conservative default)",
    "turn": {"intent": "ambiguous", "intent_confidence": 0.40},
    "expect": "strong"
  },
  {
    "kind": "invariant",
    "name": "clean response passes all invariants",
    "context": {
      "session_customer_id": "CUST-001",
      "policy_claims": ["returns_30_day"],
      "mentioned_customer_ids": ["CUST-001"]
    },
    "expect_pass": true
  },
  {
    "kind": "invariant",
    "name": "unapproved refund promise is caught",
    "context": {
      "session_customer_id": "CUST-001",
      "refund_promised": true,
      "approved_refund_exists": false
    },
    "expect_pass": false
  },
  {
    "kind": "invariant",
    "name": "invented policy is caught",
    "context": {
      "session_customer_id": "CUST-001",
      "policy_claims": ["lifetime_free_returns_forever"]
    },
    "expect_pass": false
  },
  {
    "kind": "invariant",
    "name": "leaking another customer's id is caught",
    "context": {
      "session_customer_id": "CUST-001",
      "mentioned_customer_ids": ["CUST-999"]
    },
    "expect_pass": false
  }
]
